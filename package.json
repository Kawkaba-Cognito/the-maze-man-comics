{
  "name": "maze-man-comics",
  "version": "1.0.0",
  "description": "The Maze Man Comics — Interactive bilingual psychology PWA",
  "scripts": {
    "dev": "vite",
    "dev:8080": "vite --host --port 8080 --strictPort --open /the-maze-man-comics/",
    "preview": "vite preview",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:capacitor": "vite build --mode capacitor",
    "build:android": "npm run build:capacitor && npx cap sync android",
    "audit:fq": "node scripts/audit-focus-quest-levels.mjs",
    "validate:rh": "node scripts/validate-rush-hour.mjs",
    "validate:rh:full": "node scripts/validate-rush-hour.mjs --full",
    "validate:puzzles": "node scripts/validate-puzzles.mjs",
    "build:link-words": "node scripts/build-link-words.mjs",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "cap:run:android": "npx cap run android",
    "cap:run:ios": "npx cap run ios",
    "push:both": "git push origin main && git push cognitive main",
    "deploy:live": "npm run build && npx gh-pages -d dist -r https://github.com/kawkaba-cognito/the-maze-man-comics.git",
    "ship:live": "npm run push:both && npm run deploy:live"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.0",
    "@capacitor/local-notifications": "^6.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "vite": "^8.0.2",
    "vite-plugin-pwa": "^1.2.0"
  },
  "keywords": [
    "pwa",
    "comics",
    "psychology",
    "arabic",
    "education"
  ],
  "author": "Kawkaba Cognito",
  "license": "UNLICENSED",
  "private": true
}
